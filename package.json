{
  "name": "cc-third-party-usage",
  "version": "1.1.2",
  "description": "AI API Usage Monitor - Track Kimi and GLM API usage with automatic configuration detection",
  "type": "module",
  "main": "dist/usage.js",
  "bin": {
    "cc-third-party-usage": "dist/usage.js"
  },
  "scripts": {
    "build": "rm -rf dist/* && bun build usage.mjs --target=node --outfile=dist/usage.js --target-version=22",
    "start": "bun usage.mjs",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "claude-code",
    "kimi",
    "glm",
    "api-usage",
    "monitoring",
    "cli",
    "third-party-ai",
    "statusline",
    "ai-api",
    "quota-tracker",
    "moonshot",
    "zhipu"
  ],
  "author": "Abraham Greyson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abrahamgreyson/cc-third-party-usage.git"
  },
  "bugs": {
    "url": "https://github.com/abrahamgreyson/cc-third-party-usage/issues"
  },
  "homepage": "https://github.com/abrahamgreyson/cc-third-party-usage#readme",
  "engines": {
    "node": ">=22.5.0"
  },
  "files": [
    "dist/usage.js",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
